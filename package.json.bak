    "@remotion/openai-whisper": "^4.0.436",
    "@remotion/player": "^4.0.436",
    "@remotion/rounded-text-box": "^4.0.436",
    "@remotion/shapes": "^4.0.436",
    "@sentry/tanstackstart-react": "^10.22.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/ai": "latest",
    "@tanstack/ai-anthropic": "latest",
    "@tanstack/ai-client": "latest",
    "@tanstack/ai-gemini": "latest",
